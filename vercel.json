{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["sin1"],
  "buildCommand": "prisma generate && next build",
  "installCommand": "pnpm install --frozen-lockfile=false",
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/interview-reminders",
      "schedule": "0 * * * *"
    }
  ]
}
