# PostgreSQL connection string
# Get this from https://console.neon.tech after creating a project
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require&schema=public"

# ---------------------------------------------------------------------------
# AI Engine (Sprint 4)
# ---------------------------------------------------------------------------

# Required: Google AI Studio / Vertex AI key for Gemini.
# Get yours at https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# Optional: which Gemini model to use. Defaults to "gemini-2.0-flash".
GEMINI_MODEL="gemini-2.0-flash"

# Optional: which provider the factory returns. Defaults to "gemini".
AI_PROVIDER="gemini"
