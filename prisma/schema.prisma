// TalentOS AI — Database schema
//
// Datasource: PostgreSQL (Neon in production, local Postgres for dev)
// Generator: Prisma Client
//
// Architecture notes:
//   - Every business entity carries an `organizationId` so the schema is
//     multi-tenant ready. Query-level isolation is intentionally not
//     implemented in this sprint — that lands when auth lands.
//   - IDs are UUIDs generated by the database (`@default(dbgenerated("gen_random_uuid()"))`).
//   - Every entity has `createdAt` / `updatedAt` timestamps.
//   - Enums live in the schema to keep the contract type-safe end-to-end.
//   - Soft deletes are not used; cascade rules are explicit.
//
// All enums are PascalCase strings to keep them readable in logs and APIs.

generator client {
  provider = "prisma-client-js"
  // Output to a custom path so the generated client doesn't pollute the repo
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------------------
// Enums
// -----------------------------------------------------------------------------

enum UserRole {
  ADMIN
  TA_LEAD
  RECRUITER
  HIRING_MANAGER
  INTERVIEWER
  VIEWER
  CANDIDATE
}

enum EmploymentStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  TERMINATED
}

enum HiringRequestStatus {
  DRAFT
  OPEN
  ON_HOLD
  CLOSED
  FILLED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  TEMPORARY
}

enum WorkArrangement {
  ONSITE
  REMOTE
  HYBRID
}

enum JobLevel {
  ENTRY
  JUNIOR
  MID
  SENIOR
  STAFF
  PRINCIPAL
  LEAD
  EXECUTIVE
}

enum CandidateStatus {
  ACTIVE
  HIRED
  REJECTED
  WITHDRAWN
  BLACKLISTED
}

enum ApplicationStage {
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  HIRED
  REJECTED
  WITHDRAWN
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum DegreeType {
  HIGH_SCHOOL
  ASSOCIATE
  BACHELOR
  MASTER
  PHD
  BOOTCAMP
  CERTIFICATION
  OTHER
}

enum InterviewType {
  PHONE_SCREEN
  TECHNICAL
  BEHAVIORAL
  PANEL
  ONSITE
  FINAL
  CULTURE_FIT
  CASE_STUDY
}

enum InterviewStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
  RESCHEDULED
}

enum QuestionType {
  TECHNICAL
  BEHAVIORAL
  SITUATIONAL
  CULTURAL
  CASE_STUDY
  SYSTEM_DESIGN
  CODING
}

/// Sprint 7: Where a question sits in the interview flow.
enum QuestionPurpose {
  OPENING
  ROLE_SPECIFIC
  SKILL_VALIDATION
  GAP_VALIDATION
  BEHAVIORAL
  SCENARIO
  CANDIDATE_SPECIFIC
  CLOSING
}

enum QuestionDifficulty {
  EASY
  MEDIUM
  HARD
  EXPERT
}

enum EvaluationRecommendation {
  STRONG_HIRE
  HIRE
  MIXED
  NO_HIRE
  STRONG_NO_HIRE
}

/// Sprint 8: Human Final Decision for a candidate in a hiring request.
/// AI never produces this value — it is always written by a user.
enum DecisionValue {
  ADVANCE
  HOLD
  REJECT
  SELECTED
}

enum OfferStatus {
  DRAFT
  SENT
  UNDER_REVIEW
  ACCEPTED
  DECLINED
  WITHDRAWN
  EXPIRED
}

enum SalaryCurrency {
  USD
  EUR
  GBP
  CAD
  AUD
  CHF
  JPY
  INR
  OTHER
}

enum ActivityType {
  APPLICATION_RECEIVED
  CANDIDATE_MOVED
  CANDIDATE_ADDED
  INTERVIEW_SCHEDULED
  INTERVIEW_COMPLETED
  INTERVIEW_CANCELLED
  OFFER_EXTENDED
  OFFER_ACCEPTED
  OFFER_DECLINED
  HIRED
  REJECTED
  NOTE_ADDED
  ATTACHMENT_ADDED
  HIRING_REQUEST_CREATED
  HIRING_REQUEST_UPDATED
  HIRING_REQUEST_CLOSED
  AI_TASK_STARTED
  AI_TASK_COMPLETED
  INTERVIEW_KIT_GENERATED
  EVALUATION_SUBMITTED
  DECISION_BRIEF_GENERATED
  COMPARISON_VIEWED
  CANDIDATE_SELECTED
  CANDIDATE_HELD
  CANDIDATE_REJECTED
  CANDIDATE_ADVANCED
}

enum AITaskType {
  JOB_DESCRIPTION
  SKILLS_MATRIX
  SCREENING_QUESTIONS
  INTERVIEW_QUESTIONS
  HIRING_PACKAGE
  SCORECARD
  OUTREACH
  GENERIC
  DECISION_BRIEF
}

enum AITaskStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum AIConversationRole {
  USER
  ASSISTANT
  SYSTEM
}

enum PromptTemplateCategory {
  JOB_DESCRIPTION
  INTERVIEW
  SCREENING
  EVALUATION
  OUTREACH
  GENERIC
}

enum CVFileType {
  PDF
  DOC
  DOCX
  TXT
  RTF
  OTHER
}

// -----------------------------------------------------------------------------
// Tenancy
// -----------------------------------------------------------------------------

model Organization {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  slug        String   @unique
  domain      String?  @unique
  logoUrl     String?
  website     String?
  industry    String?
  size        String?
  description String?
  settings    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  departments        Department[]
  users              User[]
  hiringRequests     HiringRequest[]
  jobDescriptions    JobDescription[]
  candidates         Candidate[]
  activities         Activity[]
  candidateDecisions CandidateDecision[]
  aiTasks            AITask[]
  promptTemplates    PromptTemplate[]
  offers             Offer[]
  interviews         Interview[]
  invitations        Invitation[]
  auditLogs          AuditLog[]

  @@index([slug])
}

model Department {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @db.Uuid
  name           String
  slug           String
  description    String?
  headUserId     String?  @db.Uuid
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  head           User?           @relation("DepartmentHead", fields: [headUserId], references: [id], onDelete: SetNull)
  users          User[]          @relation("DepartmentMembers")
  hiringRequests HiringRequest[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([organizationId, name])
}

model User {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId    String           @db.Uuid
  departmentId      String?          @db.Uuid
  email             String           @unique
  firstName         String
  lastName          String
  avatarUrl         String?
  jobTitle          String?
  role              UserRole         @default(RECRUITER)
  status            EmploymentStatus @default(ACTIVE)
  phone             String?
  location          String?
  timezone          String?
  bio               String?
  /// Bcrypt hash of the user's password. NULL only for legacy users that
  /// have not yet set a password (e.g. seeded accounts that must complete
  /// the one-time bootstrap flow before they can log in).
  passwordHash      String?
  /// Timestamp the password was last changed. Bumping this invalidates
  /// outstanding JWT sessions on their next request.
  passwordChangedAt DateTime?
  /// Timestamp the user was soft-disabled. NULL = active. Disabled users
  /// cannot log in and any existing sessions are rejected on next request.
  disabledAt        DateTime?
  lastLoginAt       DateTime?
  emailVerified     DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  organization            Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  department              Department?            @relation("DepartmentMembers", fields: [departmentId], references: [id], onDelete: SetNull)
  headOfDepartments       Department[]           @relation("DepartmentHead")
  hiringRequestsOwned     HiringRequest[]        @relation("HiringRequestHiringManager")
  hiringRequestsCreated   HiringRequest[]        @relation("HiringRequestCreator")
  scheduledInterviews     Interview[]            @relation("InterviewScheduler")
  interviewParticipations InterviewParticipant[] @relation("InterviewParticipantUser")
  evaluationsGiven        InterviewEvaluation[]
  candidateDecisions      CandidateDecision[]    @relation("CandidateDecisionMaker")
  activities              Activity[]
  aiTasks                 AITask[]
  invitationsCreated      Invitation[]           @relation("InvitationCreator")
  auditLogs               AuditLog[]             @relation("AuditLogActor")
  authSessions            AuthSession[]

  @@index([organizationId])
  @@index([organizationId, role])
  @@index([organizationId, status])
  @@index([departmentId])
  @@index([email])
}

// -----------------------------------------------------------------------------
// Hiring & Jobs
// -----------------------------------------------------------------------------

model HiringRequest {
  id               String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId   String              @db.Uuid
  departmentId     String              @db.Uuid
  createdById      String              @db.Uuid
  hiringManagerId  String?             @db.Uuid
  jobDescriptionId String?             @db.Uuid
  title            String
  slug             String
  status           HiringRequestStatus @default(DRAFT)
  priority         Priority            @default(MEDIUM)
  jobType          JobType             @default(FULL_TIME)
  workArrangement  WorkArrangement     @default(ONSITE)
  level            JobLevel            @default(MID)
  openings         Int                 @default(1)
  filled           Int                 @default(0)
  location         String?
  salaryMin        Int?
  salaryMax        Int?
  salaryCurrency   SalaryCurrency      @default(USD)
  summary          String?
  targetStartDate  DateTime?
  closingDate      DateTime?
  publishedAt      DateTime?
  closedAt         DateTime?
  settings         Json                @default("{}")
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  department         Department          @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  createdBy          User                @relation("HiringRequestCreator", fields: [createdById], references: [id], onDelete: Restrict)
  hiringManager      User?               @relation("HiringRequestHiringManager", fields: [hiringManagerId], references: [id], onDelete: SetNull)
  jobDescription     JobDescription?     @relation(fields: [jobDescriptionId], references: [id], onDelete: SetNull)
  candidates         Candidate[]
  candidateDecisions CandidateDecision[]
  interviews         Interview[]
  offers             Offer[]
  activities         Activity[]
  aiTasks            AITask[]

  @@unique([organizationId, slug])
  @@index([organizationId, status])
  @@index([organizationId, departmentId])
  @@index([departmentId, status])
  @@index([hiringManagerId])
  @@index([title])
}

model JobDescription {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId   String   @db.Uuid
  title            String
  isTemplate       Boolean  @default(false)
  level            JobLevel @default(MID)
  jobType          JobType  @default(FULL_TIME)
  summary          String?
  description      String   @db.Text
  responsibilities String[] @default([])
  requiredSkills   String[] @default([])
  niceToHave       String[] @default([])
  perks            String[] @default([])
  settings         Json     @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  hiringRequests HiringRequest[]
  aiTasks        AITask[]

  @@index([organizationId, isTemplate])
  @@index([organizationId, title])
  @@index([title])
}

// -----------------------------------------------------------------------------
// Candidates
// -----------------------------------------------------------------------------

model Candidate {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String           @db.Uuid
  hiringRequestId String           @db.Uuid
  firstName       String
  lastName        String
  email           String
  phone           String?
  location        String?
  timezone        String?
  linkedinUrl     String?
  githubUrl       String?
  portfolioUrl    String?
  avatarUrl       String?
  headline        String?
  summary         String?          @db.Text
  currentTitle    String?
  currentCompany  String?
  yearsExperience Int?
  status          CandidateStatus  @default(ACTIVE)
  stage           ApplicationStage @default(APPLIED)
  rating          Int              @default(0) // 0-5 stars
  source          String? // e.g. "Referral", "LinkedIn", "Company Site"
  sourceDetails   String?

  // AI match analysis (Sprint 6)
  // All fields nullable so the seed data and pre-existing candidates stay valid.
  // `matchScore` is 0-100. `matchScoreBreakdown` is a JSON object with per-axis
  // scores (skills, experience, education, role). `recommendation` is a
  // user-facing string ("Strong Match" | "Good Match" | "Potential Match" |
  // "Weak Match" | "Not Recommended"). Strengths/gaps/concerns are string
  // arrays produced by the AI engine.
  matchScore              Int?
  matchScoreBreakdown     Json?
  recommendation          String?
  recommendationReasoning String?   @db.Text
  strengths               String[]  @default([])
  gaps                    String[]  @default([])
  concerns                String[]  @default([])
  analyzedAt              DateTime?

  appliedAt      DateTime  @default(now())
  lastActivityAt DateTime  @default(now())
  rejectedAt     DateTime?
  rejectedReason String?
  hiredAt        DateTime?
  withdrawnAt    DateTime?
  metadata       Json      @default("{}")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization       Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  hiringRequest      HiringRequest            @relation(fields: [hiringRequestId], references: [id], onDelete: Cascade)
  skills             CandidateSkill[]
  experiences        CandidateExperience[]
  educations         CandidateEducation[]
  certifications     CandidateCertification[]
  cvFiles            CVFile[]
  interviews         Interview[]
  offers             Offer[]
  activities         Activity[]
  candidateDecisions CandidateDecision[]

  @@unique([organizationId, email, hiringRequestId])
  @@index([organizationId])
  @@index([hiringRequestId, stage])
  @@index([organizationId, stage])
  @@index([email])
  @@index([lastName, firstName])
  @@index([hiringRequestId, rating])
}

model CandidateSkill {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  candidateId String     @db.Uuid
  name        String
  level       SkillLevel @default(INTERMEDIATE)
  yearsOfUse  Int?
  isPrimary   Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([candidateId, name])
  @@index([candidateId])
  @@index([name])
}

model CandidateExperience {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  candidateId String    @db.Uuid
  company     String
  title       String
  location    String?
  startDate   DateTime
  endDate     DateTime?
  isCurrent   Boolean   @default(false)
  description String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@index([candidateId, isCurrent])
  @@index([company])
}

model CandidateEducation {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  candidateId String     @db.Uuid
  institution String
  degree      DegreeType
  field       String
  startDate   DateTime?
  endDate     DateTime?
  grade       String?
  description String?    @db.Text
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@index([institution])
  @@index([field])
}

model CandidateCertification {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  candidateId  String    @db.Uuid
  name         String
  issuer       String
  issueDate    DateTime?
  expiryDate   DateTime?
  credentialId String?
  url          String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@index([name])
  @@index([issuer])
}

model CVFile {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  candidateId String     @db.Uuid
  fileType    CVFileType
  fileName    String
  fileSize    Int // bytes
  storageUrl  String
  storagePath String?
  mimeType    String?
  parsedText  String?    @db.Text
  parsedData  Json? // structured fields extracted from the CV
  uploadedAt  DateTime   @default(now())
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
}

// -----------------------------------------------------------------------------
// Interviews
// -----------------------------------------------------------------------------

model Interview {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String           @db.Uuid
  hiringRequestId String           @db.Uuid
  candidateId     String           @db.Uuid
  scheduledById   String?          @db.Uuid
  type            InterviewType
  title           String
  description     String?          @db.Text
  status          InterviewStatus  @default(SCHEDULED)
  scheduledAt     DateTime
  durationMinutes Int              @default(60)
  location        String?
  meetingUrl      String?
  stage           ApplicationStage @default(INTERVIEW)
  round           Int              @default(1)
  notes           String?          @db.Text
  cancelledReason String?
  completedAt     DateTime?
  /// Sprint 7: AI-generated interview kit snapshot (questions, scorecard
  /// criteria, overview). Stored on the Interview so the kit can be
  /// replayed even if individual InterviewQuestion rows are edited.
  kitSnapshot     Json?
  /// Sprint 7: when the interviewer opened the kit to start the session.
  startedAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  organization  Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  hiringRequest HiringRequest          @relation(fields: [hiringRequestId], references: [id], onDelete: Cascade)
  candidate     Candidate              @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  scheduledBy   User?                  @relation("InterviewScheduler", fields: [scheduledById], references: [id], onDelete: SetNull)
  participants  InterviewParticipant[]
  questions     InterviewQuestion[]
  evaluations   InterviewEvaluation[]
  activities    Activity[]

  @@index([organizationId])
  @@index([hiringRequestId, scheduledAt])
  @@index([candidateId, scheduledAt])
  @@index([scheduledAt])
  @@index([status, scheduledAt])
}

model InterviewParticipant {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  interviewId String   @db.Uuid
  userId      String   @db.Uuid
  role        String? // e.g. "Lead", "Shadow", "Hiring Manager"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  user      User      @relation("InterviewParticipantUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([interviewId, userId])
  @@index([interviewId])
  @@index([userId])
}

model InterviewQuestion {
  id                     String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  interviewId            String             @db.Uuid
  category               String
  type                   QuestionType
  /// Sprint 7: where this question sits in the interview flow.
  purpose                QuestionPurpose    @default(ROLE_SPECIFIC)
  difficulty             QuestionDifficulty @default(MEDIUM)
  question               String             @db.Text
  /// Why this question is being asked for THIS candidate.
  whyThisQuestion        String?            @db.Text
  /// What competency or skill this question evaluates.
  whatItEvaluates        String?            @db.Text
  /// Observable indicators of a strong answer.
  strongAnswerIndicators String?            @db.Text
  /// Red flags / weak signals to watch for.
  redFlags               String?            @db.Text
  /// Suggested follow-up to dig deeper.
  suggestedFollowUp      String?            @db.Text
  expectedAnswer         String?            @db.Text
  notes                  String?            @db.Text
  order                  Int                @default(0)
  askedAt                DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@index([interviewId, order])
  @@index([interviewId, category])
  @@index([interviewId, purpose])
}

model InterviewEvaluation {
  id                  String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  interviewId         String                   @db.Uuid
  evaluatorId         String                   @db.Uuid
  overallScore        Int // 1-5
  technicalScore      Int?
  communicationScore  Int?
  cultureFitScore     Int?
  problemSolvingScore Int?
  /// Sprint 7: deterministic interview score (0–100) computed by the
  /// application from criterion scores and weights, NOT by Gemini.
  interviewScore      Int?
  /// Sprint 7: per-criterion scores, keyed by criterion name. JSON to
  /// support flexible scorecards (different jobs generate different
  /// criteria).
  criterionScores     Json?
  strengths           String?                  @db.Text
  weaknesses          String?                  @db.Text
  /// Sprint 7: free-form observations the interviewer wants to keep.
  overallNotes        String?                  @db.Text
  recommendation      EvaluationRecommendation
  summary             String?                  @db.Text
  submittedAt         DateTime                 @default(now())
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  evaluator User      @relation(fields: [evaluatorId], references: [id], onDelete: Restrict)

  @@index([interviewId])
  @@index([evaluatorId])
  @@index([recommendation])
}

// -----------------------------------------------------------------------------
// Offers
// -----------------------------------------------------------------------------

model Offer {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String         @db.Uuid
  hiringRequestId String         @db.Uuid
  candidateId     String         @db.Uuid
  status          OfferStatus    @default(DRAFT)
  title           String
  salaryAmount    Int
  salaryCurrency  SalaryCurrency @default(USD)
  salaryPeriod    String         @default("annual") // annual, monthly, hourly
  bonusAmount     Int?
  equityAmount    String? // free-form e.g. "0.05% over 4 years"
  startDate       DateTime?
  expiresAt       DateTime?
  sentAt          DateTime?
  respondedAt     DateTime?
  acceptedAt      DateTime?
  declinedAt      DateTime?
  declineReason   String?
  notes           String?        @db.Text
  documentUrl     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  hiringRequest HiringRequest @relation(fields: [hiringRequestId], references: [id], onDelete: Cascade)
  candidate     Candidate     @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  activities    Activity[]

  @@index([organizationId])
  @@index([hiringRequestId])
  @@index([candidateId])
  @@index([status])
}

// -----------------------------------------------------------------------------
// Activity
// -----------------------------------------------------------------------------

model Activity {
  id                  String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId      String       @db.Uuid
  type                ActivityType
  actorId             String?      @db.Uuid
  candidateId         String?      @db.Uuid
  hiringRequestId     String?      @db.Uuid
  interviewId         String?      @db.Uuid
  offerId             String?      @db.Uuid
  candidateDecisionId String?      @db.Uuid
  title               String
  description         String?      @db.Text
  metadata            Json         @default("{}")
  occurredAt          DateTime     @default(now())
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor             User?              @relation(fields: [actorId], references: [id], onDelete: SetNull)
  candidate         Candidate?         @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  hiringRequest     HiringRequest?     @relation(fields: [hiringRequestId], references: [id], onDelete: Cascade)
  interview         Interview?         @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  offer             Offer?             @relation(fields: [offerId], references: [id], onDelete: Cascade)
  candidateDecision CandidateDecision? @relation(fields: [candidateDecisionId], references: [id], onDelete: Cascade)

  @@index([organizationId, occurredAt])
  @@index([organizationId, type])
  @@index([candidateId, occurredAt])
  @@index([hiringRequestId, occurredAt])
  @@index([actorId, occurredAt])
}

// -----------------------------------------------------------------------------
// AI
// -----------------------------------------------------------------------------

model AITask {
  id               String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId   String       @db.Uuid
  hiringRequestId  String?      @db.Uuid
  jobDescriptionId String?      @db.Uuid
  createdById      String?      @db.Uuid
  type             AITaskType
  title            String
  status           AITaskStatus @default(PENDING)
  prompt           String       @db.Text
  result           Json?
  errorMessage     String?
  metadata         Json         @default("{}")
  inputTokens      Int?
  outputTokens     Int?
  modelUsed        String?
  durationMs       Int?
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  hiringRequest  HiringRequest?   @relation(fields: [hiringRequestId], references: [id], onDelete: SetNull)
  jobDescription JobDescription?  @relation(fields: [jobDescriptionId], references: [id], onDelete: SetNull)
  createdBy      User?            @relation(fields: [createdById], references: [id], onDelete: SetNull)
  conversations  AIConversation[]

  @@index([organizationId, status])
  @@index([organizationId, type])
  @@index([hiringRequestId])
  @@index([createdById, createdAt])
}

model AIConversation {
  id        String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  taskId    String             @db.Uuid
  role      AIConversationRole
  content   String             @db.Text
  tokens    Int?
  metadata  Json               @default("{}")
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  task AITask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
}

model PromptTemplate {
  id             String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String?                @db.Uuid
  name           String
  description    String?
  category       PromptTemplateCategory
  body           String                 @db.Text
  variables      Json                   @default("[]")
  isPublic       Boolean                @default(false)
  version        Int                    @default(1)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, category])
  @@index([category, isPublic])
  @@index([name])
}

// -----------------------------------------------------------------------------
// Sprint 8: CandidateDecision
// -----------------------------------------------------------------------------
// A human-written final decision for a candidate in a hiring request.
// One row per (candidate, hiringRequest). The decision is always written
// by an authenticated user; the AI never produces or modifies it.

model CandidateDecision {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String        @db.Uuid
  candidateId     String        @db.Uuid
  hiringRequestId String        @db.Uuid
  decision        DecisionValue
  /// Free-form notes the decision-maker wrote when recording the decision.
  notes           String?       @db.Text
  /// Optional short reason label (e.g. "Strongest match" or "Better fit available").
  reason          String?
  /// Audit: who recorded the decision and when.
  decidedById     String        @db.Uuid
  decidedAt       DateTime      @default(now())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  candidate     Candidate     @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  hiringRequest HiringRequest @relation(fields: [hiringRequestId], references: [id], onDelete: Cascade)
  decidedBy     User          @relation("CandidateDecisionMaker", fields: [decidedById], references: [id], onDelete: Restrict)
  activities    Activity[]

  @@unique([candidateId, hiringRequestId])
  @@index([organizationId])
  @@index([hiringRequestId, decision])
  @@index([candidateId])
}

// -----------------------------------------------------------------------------
// Sprint 9 — Identity, Authentication, RBAC, Multi-Tenancy, Security
// -----------------------------------------------------------------------------

/// Invitation to join an Organization with a specific role.
///
/// Sprint 9 PART 16: ADMIN and authorized TA_LEAD users can invite teammates.
/// Tokens are generated via `crypto.randomBytes(32)`, and only a SHA-256 hash
/// of the token is stored in the database. The plaintext token is returned
/// ONCE to the inviter (because no email infrastructure is configured yet).
enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

model Invitation {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String           @db.Uuid
  email          String
  role           UserRole
  status         InvitationStatus @default(PENDING)
  /// SHA-256 hash of the raw invitation token. The plaintext is only
  /// available to the inviter at creation time and to the recipient when
  /// they accept the invitation. We never persist the plaintext.
  tokenHash      String           @unique
  /// Prefix of the raw token (first 8 chars) shown in the UI so admins
  /// can identify invitations without revealing the secret. Used only for
  /// display in the "Pending Invitations" list.
  tokenPrefix    String
  invitedById    String           @db.Uuid
  expiresAt      DateTime
  acceptedAt     DateTime?
  acceptedById   String?          @db.Uuid
  revokedAt      DateTime?
  revokedById    String?          @db.Uuid
  /// Optional one-time message from the inviter.
  message        String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation("InvitationCreator", fields: [invitedById], references: [id], onDelete: Restrict)

  @@index([organizationId, status])
  @@index([email])
  @@index([expiresAt])
}

/// Security audit log. Separate from the business `Activity` model so that
/// security events (login attempts, role changes, denied access) can never
/// be conflated with hiring activity, can be reviewed independently, and
/// are append-only from the application's perspective.
///
/// PART 20: stores actor, organization, action, target, timestamp, and
/// safe metadata. NEVER store: passwords, raw session tokens, plaintext
/// invitation tokens, API keys, or CV content.
model AuditLog {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String?  @db.Uuid
  actorId        String?  @db.Uuid
  action         String // e.g. LOGIN_SUCCESS, LOGIN_FAILURE, INVITATION_CREATED
  /// Target type, e.g. "user", "invitation", "candidate", "hiring_request"
  targetType     String?
  /// Target ID (when the target is in the same organization)
  targetId       String?
  /// Outcome: "success" | "failure" | "denied"
  outcome        String   @default("success")
  /// Free-form reason (e.g. "invalid_password", "user_disabled", "tenant_mismatch")
  reason         String?
  /// Safe metadata (request ID, IP, user agent — but never secrets).
  metadata       Json     @default("{}")
  occurredAt     DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  actor        User?         @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([organizationId, occurredAt])
  @@index([actorId, occurredAt])
  @@index([action, occurredAt])
  @@index([targetType, targetId])
}

/// Server-side session record. With Auth.js JWT strategy the JWT itself is
/// the source of truth, but we keep a DB row so that:
///   1. ADMIN can revoke an individual session (kills the row, JWT becomes
///      invalid even though its signature is still valid).
///   2. We can list active sessions per user in the Security settings page.
///   3. Disabled users can be logged out globally by deleting their rows.
model AuthSession {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String    @db.Uuid
  /// SHA-256 hash of the session token. The raw cookie value is never stored.
  sessionTokenHash String    @unique
  /// JWT `jti` claim (unique identifier) so we can map a JWT back to this row.
  jwtId            String?   @unique
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  lastUsedAt       DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
