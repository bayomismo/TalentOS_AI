// TalentOS AI — Database schema
//
// Datasource: PostgreSQL (Neon in production, local Postgres for dev)
// Generator: Prisma Client
//
// Architecture notes:
//   - Every business entity carries an `organizationId` so the schema is
//     multi-tenant ready. Query-level isolation is intentionally not
//     implemented in this sprint — that lands when auth lands.
//   - IDs are UUIDs generated by the database (`@default(dbgenerated("gen_random_uuid()"))`).
//   - Every entity has `createdAt` / `updatedAt` timestamps.
//   - Enums live in the schema to keep the contract type-safe end-to-end.
//   - Soft deletes are not used; cascade rules are explicit.
//
// All enums are PascalCase strings to keep them readable in logs and APIs.

generator client {
  provider = "prisma-client-js"
  // Output to a custom path so the generated client doesn't pollute the repo
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------------------
// Enums
// -----------------------------------------------------------------------------

enum UserRole {
  ADMIN
  RECRUITER
  HIRING_MANAGER
  INTERVIEWER
  CANDIDATE
}

enum EmploymentStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  TERMINATED
}

enum HiringRequestStatus {
  DRAFT
  OPEN
  ON_HOLD
  CLOSED
  FILLED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  TEMPORARY
}

enum WorkArrangement {
  ONSITE
  REMOTE
  HYBRID
}

enum JobLevel {
  ENTRY
  JUNIOR
  MID
  SENIOR
  STAFF
  PRINCIPAL
  LEAD
  EXECUTIVE
}

enum CandidateStatus {
  ACTIVE
  HIRED
  REJECTED
  WITHDRAWN
  BLACKLISTED
}

enum ApplicationStage {
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  HIRED
  REJECTED
  WITHDRAWN
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum DegreeType {
  HIGH_SCHOOL
  ASSOCIATE
  BACHELOR
  MASTER
  PHD
  BOOTCAMP
  CERTIFICATION
  OTHER
}

enum InterviewType {
  PHONE_SCREEN
  TECHNICAL
  BEHAVIORAL
  PANEL
  ONSITE
  FINAL
  CULTURE_FIT
  CASE_STUDY
}

enum InterviewStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
  RESCHEDULED
}

enum QuestionType {
  TECHNICAL
  BEHAVIORAL
  SITUATIONAL
  CULTURAL
  CASE_STUDY
  SYSTEM_DESIGN
  CODING
}

enum QuestionDifficulty {
  EASY
  MEDIUM
  HARD
  EXPERT
}

enum EvaluationRecommendation {
  STRONG_HIRE
  HIRE
  NO_HIRE
  STRONG_NO_HIRE
}

enum OfferStatus {
  DRAFT
  SENT
  UNDER_REVIEW
  ACCEPTED
  DECLINED
  WITHDRAWN
  EXPIRED
}

enum SalaryCurrency {
  USD
  EUR
  GBP
  CAD
  AUD
  CHF
  JPY
  INR
  OTHER
}

enum ActivityType {
  APPLICATION_RECEIVED
  CANDIDATE_MOVED
  CANDIDATE_ADDED
  INTERVIEW_SCHEDULED
  INTERVIEW_COMPLETED
  INTERVIEW_CANCELLED
  OFFER_EXTENDED
  OFFER_ACCEPTED
  OFFER_DECLINED
  HIRED
  REJECTED
  NOTE_ADDED
  ATTACHMENT_ADDED
  HIRING_REQUEST_CREATED
  HIRING_REQUEST_UPDATED
  HIRING_REQUEST_CLOSED
  AI_TASK_STARTED
  AI_TASK_COMPLETED
}

enum AITaskType {
  JOB_DESCRIPTION
  SKILLS_MATRIX
  SCREENING_QUESTIONS
  INTERVIEW_QUESTIONS
  HIRING_PACKAGE
  SCORECARD
  OUTREACH
  GENERIC
}

enum AITaskStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum AIConversationRole {
  USER
  ASSISTANT
  SYSTEM
}

enum PromptTemplateCategory {
  JOB_DESCRIPTION
  INTERVIEW
  SCREENING
  EVALUATION
  OUTREACH
  GENERIC
}

enum CVFileType {
  PDF
  DOC
  DOCX
  TXT
  RTF
  OTHER
}

// -----------------------------------------------------------------------------
// Tenancy
// -----------------------------------------------------------------------------

model Organization {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  slug        String   @unique
  domain      String?  @unique
  logoUrl     String?
  website     String?
  industry    String?
  size        String?
  description String?
  settings    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  departments     Department[]
  users           User[]
  hiringRequests  HiringRequest[]
  jobDescriptions JobDescription[]
  candidates      Candidate[]
  activities      Activity[]
  aiTasks         AITask[]
  promptTemplates PromptTemplate[]
  offers          Offer[]
  interviews      Interview[]

  @@index([slug])
}

model Department {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @db.Uuid
  name           String
  slug           String
  description    String?
  headUserId     String?  @db.Uuid
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  head            User?            @relation("DepartmentHead", fields: [headUserId], references: [id], onDelete: SetNull)
  users           User[]           @relation("DepartmentMembers")
  hiringRequests  HiringRequest[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([organizationId, name])
}

model User {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String           @db.Uuid
  departmentId   String?          @db.Uuid
  email          String           @unique
  firstName      String
  lastName       String
  avatarUrl      String?
  jobTitle       String?
  role           UserRole         @default(RECRUITER)
  status         EmploymentStatus @default(ACTIVE)
  phone          String?
  location       String?
  timezone       String?
  bio            String?
  lastLoginAt    DateTime?
  emailVerified  DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  department          Department?          @relation("DepartmentMembers", fields: [departmentId], references: [id], onDelete: SetNull)
  headOfDepartments   Department[]         @relation("DepartmentHead")
  hiringRequestsOwned HiringRequest[]      @relation("HiringRequestHiringManager")
  hiringRequestsCreated HiringRequest[]    @relation("HiringRequestCreator")
  scheduledInterviews Interview[]          @relation("InterviewScheduler")
  interviewParticipations InterviewParticipant[] @relation("InterviewParticipantUser")
  evaluationsGiven   InterviewEvaluation[]
  activities          Activity[]
  aiTasks             AITask[]

  @@index([organizationId])
  @@index([organizationId, role])
  @@index([departmentId])
  @@index([email])
}

// -----------------------------------------------------------------------------
// Hiring & Jobs
// -----------------------------------------------------------------------------

model HiringRequest {
  id              String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String              @db.Uuid
  departmentId    String              @db.Uuid
  createdById     String              @db.Uuid
  hiringManagerId String?             @db.Uuid
  jobDescriptionId String?            @db.Uuid
  title           String
  slug            String
  status          HiringRequestStatus @default(DRAFT)
  priority        Priority            @default(MEDIUM)
  jobType         JobType             @default(FULL_TIME)
  workArrangement WorkArrangement     @default(ONSITE)
  level           JobLevel            @default(MID)
  openings        Int                 @default(1)
  filled          Int                 @default(0)
  location        String?
  salaryMin       Int?
  salaryMax       Int?
  salaryCurrency  SalaryCurrency      @default(USD)
  summary         String?
  targetStartDate DateTime?
  closingDate     DateTime?
  publishedAt     DateTime?
  closedAt        DateTime?
  settings        Json                @default("{}")
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  department     Department          @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  createdBy      User                @relation("HiringRequestCreator", fields: [createdById], references: [id], onDelete: Restrict)
  hiringManager  User?               @relation("HiringRequestHiringManager", fields: [hiringManagerId], references: [id], onDelete: SetNull)
  jobDescription JobDescription?     @relation(fields: [jobDescriptionId], references: [id], onDelete: SetNull)
  candidates     Candidate[]
  interviews     Interview[]
  offers         Offer[]
  activities     Activity[]
  aiTasks        AITask[]

  @@unique([organizationId, slug])
  @@index([organizationId, status])
  @@index([organizationId, departmentId])
  @@index([departmentId, status])
  @@index([hiringManagerId])
  @@index([title])
}

model JobDescription {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @db.Uuid
  title          String
  isTemplate     Boolean  @default(false)
  level          JobLevel @default(MID)
  jobType        JobType  @default(FULL_TIME)
  summary        String?
  description    String   @db.Text
  responsibilities String[] @default([])
  requiredSkills String[] @default([])
  niceToHave     String[] @default([])
  perks          String[] @default([])
  settings       Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  hiringRequests  HiringRequest[]
  aiTasks         AITask[]

  @@index([organizationId, isTemplate])
  @@index([organizationId, title])
  @@index([title])
}

// -----------------------------------------------------------------------------
// Candidates
// -----------------------------------------------------------------------------

model Candidate {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String          @db.Uuid
  hiringRequestId String          @db.Uuid
  firstName       String
  lastName        String
  email           String
  phone           String?
  location        String?
  timezone        String?
  linkedinUrl     String?
  githubUrl       String?
  portfolioUrl    String?
  avatarUrl       String?
  headline        String?
  summary         String?         @db.Text
  currentTitle    String?
  currentCompany  String?
  yearsExperience Int?
  status          CandidateStatus @default(ACTIVE)
  stage           ApplicationStage @default(APPLIED)
  rating          Int             @default(0) // 0-5 stars
  source          String?         // e.g. "Referral", "LinkedIn", "Company Site"
  sourceDetails   String?

  // AI match analysis (Sprint 6)
  // All fields nullable so the seed data and pre-existing candidates stay valid.
  // `matchScore` is 0-100. `matchScoreBreakdown` is a JSON object with per-axis
  // scores (skills, experience, education, role). `recommendation` is a
  // user-facing string ("Strong Match" | "Good Match" | "Potential Match" |
  // "Weak Match" | "Not Recommended"). Strengths/gaps/concerns are string
  // arrays produced by the AI engine.
  matchScore             Int?
  matchScoreBreakdown    Json?
  recommendation         String?
  recommendationReasoning String?  @db.Text
  strengths              String[] @default([])
  gaps                   String[] @default([])
  concerns               String[] @default([])
  analyzedAt             DateTime?

  appliedAt       DateTime        @default(now())
  lastActivityAt  DateTime        @default(now())
  rejectedAt      DateTime?
  rejectedReason  String?
  hiredAt         DateTime?
  withdrawnAt     DateTime?
  metadata        Json            @default("{}")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  hiringRequest   HiringRequest       @relation(fields: [hiringRequestId], references: [id], onDelete: Cascade)
  skills          CandidateSkill[]
  experiences     CandidateExperience[]
  educations      CandidateEducation[]
  certifications  CandidateCertification[]
  cvFiles         CVFile[]
  interviews      Interview[]
  offers          Offer[]
  activities      Activity[]

  @@unique([organizationId, email, hiringRequestId])
  @@index([organizationId])
  @@index([hiringRequestId, stage])
  @@index([organizationId, stage])
  @@index([email])
  @@index([lastName, firstName])
  @@index([hiringRequestId, rating])
}

model CandidateSkill {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  candidateId String     @db.Uuid
  name        String
  level       SkillLevel @default(INTERMEDIATE)
  yearsOfUse  Int?
  isPrimary   Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([candidateId, name])
  @@index([candidateId])
  @@index([name])
}

model CandidateExperience {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  candidateId String    @db.Uuid
  company     String
  title       String
  location    String?
  startDate   DateTime
  endDate     DateTime?
  isCurrent   Boolean   @default(false)
  description String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@index([candidateId, isCurrent])
  @@index([company])
}

model CandidateEducation {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  candidateId String     @db.Uuid
  institution String
  degree      DegreeType
  field       String
  startDate   DateTime?
  endDate     DateTime?
  grade       String?
  description String?    @db.Text
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@index([institution])
  @@index([field])
}

model CandidateCertification {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  candidateId String    @db.Uuid
  name        String
  issuer      String
  issueDate   DateTime?
  expiryDate  DateTime?
  credentialId String?
  url         String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@index([name])
  @@index([issuer])
}

model CVFile {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  candidateId   String     @db.Uuid
  fileType      CVFileType
  fileName      String
  fileSize      Int        // bytes
  storageUrl    String
  storagePath   String?
  mimeType      String?
  parsedText    String?    @db.Text
  parsedData    Json?      // structured fields extracted from the CV
  uploadedAt    DateTime   @default(now())
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
}

// -----------------------------------------------------------------------------
// Interviews
// -----------------------------------------------------------------------------

model Interview {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String          @db.Uuid
  hiringRequestId String          @db.Uuid
  candidateId     String          @db.Uuid
  scheduledById   String?         @db.Uuid
  type            InterviewType
  title           String
  description     String?         @db.Text
  status          InterviewStatus @default(SCHEDULED)
  scheduledAt     DateTime
  durationMinutes Int             @default(60)
  location        String?
  meetingUrl      String?
  stage           ApplicationStage @default(INTERVIEW)
  round           Int             @default(1)
  notes           String?         @db.Text
  cancelledReason String?
  completedAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  hiringRequest  HiringRequest           @relation(fields: [hiringRequestId], references: [id], onDelete: Cascade)
  candidate      Candidate               @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  scheduledBy    User?                   @relation("InterviewScheduler", fields: [scheduledById], references: [id], onDelete: SetNull)
  participants   InterviewParticipant[]
  questions      InterviewQuestion[]
  evaluations    InterviewEvaluation[]
  activities     Activity[]

  @@index([organizationId])
  @@index([hiringRequestId, scheduledAt])
  @@index([candidateId, scheduledAt])
  @@index([scheduledAt])
  @@index([status, scheduledAt])
}

model InterviewParticipant {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  interviewId String   @db.Uuid
  userId      String   @db.Uuid
  role        String?  // e.g. "Lead", "Shadow", "Hiring Manager"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  user      User      @relation("InterviewParticipantUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([interviewId, userId])
  @@index([interviewId])
  @@index([userId])
}

model InterviewQuestion {
  id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  interviewId String            @db.Uuid
  category    String
  type        QuestionType
  difficulty  QuestionDifficulty @default(MEDIUM)
  question    String             @db.Text
  expectedAnswer String?         @db.Text
  notes       String?            @db.Text
  order       Int               @default(0)
  askedAt     DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@index([interviewId, order])
  @@index([interviewId, category])
}

model InterviewEvaluation {
  id              String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  interviewId     String                  @db.Uuid
  evaluatorId     String                  @db.Uuid
  overallScore    Int                     // 1-5
  technicalScore  Int?
  communicationScore Int?
  cultureFitScore Int?
  problemSolvingScore Int?
  strengths       String?                 @db.Text
  weaknesses      String?                 @db.Text
  recommendation  EvaluationRecommendation
  summary         String?                 @db.Text
  submittedAt     DateTime                @default(now())
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  evaluator User      @relation(fields: [evaluatorId], references: [id], onDelete: Restrict)

  @@index([interviewId])
  @@index([evaluatorId])
  @@index([recommendation])
}

// -----------------------------------------------------------------------------
// Offers
// -----------------------------------------------------------------------------

model Offer {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String      @db.Uuid
  hiringRequestId String      @db.Uuid
  candidateId     String      @db.Uuid
  status          OfferStatus @default(DRAFT)
  title           String
  salaryAmount    Int
  salaryCurrency  SalaryCurrency @default(USD)
  salaryPeriod    String      @default("annual") // annual, monthly, hourly
  bonusAmount     Int?
  equityAmount    String?     // free-form e.g. "0.05% over 4 years"
  startDate       DateTime?
  expiresAt       DateTime?
  sentAt          DateTime?
  respondedAt     DateTime?
  acceptedAt      DateTime?
  declinedAt      DateTime?
  declineReason   String?
  notes           String?     @db.Text
  documentUrl     String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  hiringRequest HiringRequest @relation(fields: [hiringRequestId], references: [id], onDelete: Cascade)
  candidate     Candidate     @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  activities    Activity[]

  @@index([organizationId])
  @@index([hiringRequestId])
  @@index([candidateId])
  @@index([status])
}

// -----------------------------------------------------------------------------
// Activity
// -----------------------------------------------------------------------------

model Activity {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String        @db.Uuid
  type            ActivityType
  actorId         String?       @db.Uuid
  candidateId     String?       @db.Uuid
  hiringRequestId String?       @db.Uuid
  interviewId     String?       @db.Uuid
  offerId         String?       @db.Uuid
  title           String
  description     String?       @db.Text
  metadata        Json          @default("{}")
  occurredAt      DateTime      @default(now())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor         User?          @relation(fields: [actorId], references: [id], onDelete: SetNull)
  candidate     Candidate?     @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  hiringRequest HiringRequest? @relation(fields: [hiringRequestId], references: [id], onDelete: Cascade)
  interview     Interview?     @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  offer         Offer?         @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@index([organizationId, occurredAt])
  @@index([organizationId, type])
  @@index([candidateId, occurredAt])
  @@index([hiringRequestId, occurredAt])
  @@index([actorId, occurredAt])
}

// -----------------------------------------------------------------------------
// AI
// -----------------------------------------------------------------------------

model AITask {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String       @db.Uuid
  hiringRequestId String?      @db.Uuid
  jobDescriptionId String?     @db.Uuid
  createdById     String?      @db.Uuid
  type            AITaskType
  title           String
  status          AITaskStatus @default(PENDING)
  prompt          String       @db.Text
  result          Json?
  errorMessage    String?
  inputTokens     Int?
  outputTokens    Int?
  modelUsed       String?
  durationMs      Int?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  hiringRequest  HiringRequest?  @relation(fields: [hiringRequestId], references: [id], onDelete: SetNull)
  jobDescription JobDescription? @relation(fields: [jobDescriptionId], references: [id], onDelete: SetNull)
  createdBy      User?           @relation(fields: [createdById], references: [id], onDelete: SetNull)
  conversations  AIConversation[]

  @@index([organizationId, status])
  @@index([organizationId, type])
  @@index([hiringRequestId])
  @@index([createdById, createdAt])
}

model AIConversation {
  id          String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  taskId      String               @db.Uuid
  role        AIConversationRole
  content     String               @db.Text
  tokens      Int?
  metadata    Json                 @default("{}")
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  task AITask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
}

model PromptTemplate {
  id             String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String?               @db.Uuid
  name           String
  description    String?
  category       PromptTemplateCategory
  body           String                @db.Text
  variables      Json                  @default("[]")
  isPublic       Boolean               @default(false)
  version        Int                   @default(1)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, category])
  @@index([category, isPublic])
  @@index([name])
}
